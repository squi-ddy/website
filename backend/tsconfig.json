{
    "compilerOptions": {
        "module": "Node16",
        "esModuleInterop": true,
        "target": "es2022",
        "moduleResolution": "node16",
        "sourceMap": true,
        "outDir": "dist",
        "rootDir": "src",
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "strict": true
    },
    "lib": ["es2022"]
}
